@page
@model WebWatchParty.Pages.RoomModel
@{
    ViewData["Title"] = "Room: " + Model.RoomId;
}

<div id="roomApp" class="room-shell" data-room-id="@Model.RoomId" data-user-name="@Model.UserName">
    <section class="wwp-card room-hero mb-4">
        <div>
            <p class="eyebrow mb-2">Live watch room</p>
            <h1 class="room-title mb-2">@Model.RoomId</h1>
            <p class="room-subtitle mb-0">Watch together, talk live, and let the room admin keep things in sync.</p>
        </div>
        <div class="room-hero-meta">
            <span id="connectionBadge" class="status-chip status-chip-muted">Connecting…</span>
            <span id="adminBadge" class="status-chip status-chip-admin d-none">Admin controls enabled</span>
            <span class="status-chip">@Model.UserName</span>
        </div>
    </section>

    <div id="roomAlert" class="alert alert-danger d-none" role="alert"></div>

    <div class="row g-4 align-items-stretch">
        <div class="col-12 col-xl-8">
            <section class="wwp-card video-card h-100">
                <div class="section-header mb-3">
                    <div>
                        <p class="section-kicker mb-1">Synchronized playback</p>
                        <h2 class="section-title mb-0">YouTube player</h2>
                    </div>
                    <div class="status-stack text-xl-end">
                        <span id="syncStatus" class="section-note">Ready for the next video.</span>
                        <span id="roomModeLabel" class="section-note">Viewer mode</span>
                    </div>
                </div>

                <div class="admin-control-row mb-3">
                    <label class="form-label visually-hidden" for="videoUrl">YouTube URL</label>
                    <input type="text" id="videoUrl" class="form-control" placeholder="Paste a YouTube link to load it for everyone">
                    <button id="changeUrlBtn" class="btn btn-primary">Load video</button>
                </div>

                <div id="videoContainer" class="video-stage mb-3">
                    <div id="player"></div>
                </div>

                <div class="video-actions">
                    <button id="btnPlay" class="btn btn-success">Play</button>
                    <button id="btnPause" class="btn btn-outline-light">Pause</button>
                    <a class="btn btn-outline-light" asp-page="/Index">Leave room</a>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4 d-flex flex-column gap-4">
            <section class="wwp-card voice-card">
                <div class="section-header mb-3">
                    <div>
                        <p class="section-kicker mb-1">Voice chat</p>
                        <h2 class="section-title mb-0">Talk live</h2>
                    </div>
                    <span id="voiceStatusBadge" class="status-chip status-chip-muted">Voice off</span>
                </div>

                <p id="voiceStatusText" class="section-note mb-3">Enable your microphone to talk with everyone in the room.</p>

                <div class="voice-actions">
                    <button id="voiceJoinBtn" class="btn btn-primary">Enable voice</button>
                    <button id="voiceMuteBtn" class="btn btn-outline-light" disabled>Mute mic</button>
                    <button id="voiceLeaveBtn" class="btn btn-outline-danger" disabled>Leave voice</button>
                </div>

                <div id="audioStage" class="audio-stage mt-3"></div>
            </section>

            <section class="wwp-card participants-card">
                <div class="section-header mb-3">
                    <div>
                        <p class="section-kicker mb-1">Presence</p>
                        <h2 class="section-title mb-0">Participants</h2>
                    </div>
                    <span id="participantCount" class="status-chip">0 online</span>
                </div>

                <div id="participantsList" class="participants-list"></div>
            </section>

            <section class="wwp-card chat-card flex-grow-1">
                <div class="section-header mb-3">
                    <div>
                        <p class="section-kicker mb-1">Room chat</p>
                        <h2 class="section-title mb-0">Messages</h2>
                    </div>
                </div>

                <div id="chatMessages" class="chat-messages"></div>

                <div class="chat-composer mt-3">
                    <input type="text" id="chatInput" class="form-control" placeholder="Type a message for the room">
                    <button id="sendBtn" class="btn btn-primary">Send</button>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
    <script src="~/js/room.js" asp-append-version="true"></script>
}
