<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebWatchParty</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebWatchParty.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <div class="container-xxl app-header-inner">
                <a class="app-brand" asp-area="" asp-page="/Index">
                    <span class="app-brand-mark">▶</span>
                    <span>WebWatchParty</span>
                </a>

                <nav class="app-nav">
                    <a class="app-nav-link" asp-area="" asp-page="/Index">Home</a>
                    <span class="app-nav-text">Watch together · voice together</span>
                </nav>
            </div>
        </header>

        <main role="main" class="app-main container-xxl pb-4">
            @RenderBody()
        </main>

        <footer class="app-footer container-xxl">
            <span>&copy; 2026 WebWatchParty</span>
            <span>Shared playback, in-room chat, and browser voice chat.</span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
